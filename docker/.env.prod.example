# =============================================================================
# Educathing production .env
# -----------------------------------------------------------------------------
# The install.sh script generates a working .env from this template with strong
# random secrets. If you edit it by hand, keep the same variable names.
# =============================================================================

# ------- Reverse proxy / TLS ------------------------------------------------
# The hostname Caddy serves. Use a real domain to get an automatic Let's
# Encrypt certificate. Use "localhost" to test the stack before DNS is ready
# (Caddy will issue a local self-signed cert instead).
DOMAIN=localhost
ACME_EMAIL=admin@localhost

# ------- App runtime --------------------------------------------------------
SERVER_PORT=3001
STORAGE_DIR=/app/server/storage
# Required for the built-in DOCX/PDF generators (create-files agent).
ANYTHING_LLM_RUNTIME=docker
# Disable anonymous telemetry to satisfy Law 21.719 default posture.
DISABLE_TELEMETRY=true

# ------- Authentication -----------------------------------------------------
# install.sh fills these with `openssl rand -hex 32`. Never commit real values.
SIG_KEY=REPLACE_ME_32_CHAR_MIN
SIG_SALT=REPLACE_ME_32_CHAR_MIN
JWT_SECRET=REPLACE_ME_32_CHAR_MIN
# Optional: single-instance auth token; leave unset to use multi-user mode.
# AUTH_TOKEN=

# ------- LLM provider: OpenRouter ------------------------------------------
# Educathing routes free/paid models through OpenRouter. Set the API key here;
# per-workspace model preferences are configured from the admin UI using the
# built-in Dynamic Model Router.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=REPLACE_ME_OPENROUTER_KEY
# Default model when a workspace has no explicit preference. "openrouter/auto"
# lets OpenRouter pick; swap for an explicit slug in production.
OPENROUTER_MODEL_PREF=openrouter/auto

# ------- Embedder -----------------------------------------------------------
# Defaults to the built-in local embedder — no external key required. Uncomment
# and configure an alternative provider only if you have a strong reason.
# EMBEDDING_ENGINE=openai
# EMBEDDING_MODEL_PREF=text-embedding-3-small
# OPEN_AI_KEY=

# ------- Vector DB ----------------------------------------------------------
# Local LanceDB is the default and lives inside STORAGE_DIR; nothing to set.
# VECTOR_DB=lancedb
